# Auth.js v5 (RP mode, shares secret with noclulabs.com for cookie-based SSO)
# AUTH_SECRET MUST match noclulabs.com's value exactly for the SSO bridge to work.
# Generate with: openssl rand -base64 32 (only if you are also rotating noclulabs')
AUTH_SECRET=

# In production: https://cal.noclulabs.com
# In local dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# Required when running behind a reverse proxy (Caddy in prod).
# Safe to set in dev as well.
AUTH_TRUST_HOST=true

# Phase 1b will add:
# DATABASE_URL=postgresql://noclucal:noclucal@localhost:5434/noclucal_dev?sslmode=disable
