# Auth.js v5 (RP mode, shares secret with noclulabs.com for cookie-based SSO)
# AUTH_SECRET MUST match noclulabs.com's value exactly for the SSO bridge to work.
# Generate with: openssl rand -base64 32 (only if you are also rotating noclulabs')
AUTH_SECRET=

# In production: https://cal.noclulabs.com
# In local dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# Required when running behind a reverse proxy (Caddy in prod).
# Safe to set in dev as well.
AUTH_TRUST_HOST=true

# AES-256-GCM key used to encrypt OAuth tokens at rest in calendar_connections.
# Generate with: openssl rand -base64 32
# MUST decode to exactly 32 bytes. Different value per environment.
# Production value lives in Bitwarden under "noClu Infrastructure".
TOKEN_ENCRYPTION_KEY=

# Google OAuth client credentials for the Google Calendar provider.
# Created in Google Cloud Console; production value lives in Bitwarden
# under "noClu Infrastructure". Phase 2d's OAuth callback route is the
# first runtime consumer; Phase 2c imports the provider but does not
# invoke it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL connection. Local dev points at the docker-compose.dev.yml Postgres on port 5434.
# Production points at the DigitalOcean Managed Postgres cluster's `noclucal_prod` database;
# the prod URL MUST end with &uselibpqcompat=true (see CLAUDE.md § Database / SSL workaround).
DATABASE_URL=postgresql://noclucal:noclucal@localhost:5434/noclucal_dev?sslmode=disable

# Redis connection for BullMQ (rate limiting and background jobs). Local dev
# points at the docker-compose.dev.yml Redis on host port 6380. Production uses
# the compose-network address redis://redis:6379 (set in the droplet .env).
REDIS_URL=redis://localhost:6380

# Resend, for the branded transactional emails. Both become required in prod
# when sending goes live in Phase 5c; nothing sends in 5b, and tests mock the
# client, so dummy values are fine locally. EMAIL_FROM must be a sender on a
# domain verified in Resend. Production values live in Bitwarden under
# "noClu Infrastructure".
RESEND_API_KEY=
EMAIL_FROM="noCluCal <bookings@cal.noclulabs.com>"
