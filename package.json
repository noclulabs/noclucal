{
  "name": "noclucal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:smoke": "node --env-file=.env.local --import tsx scripts/db-smoke-test.ts",
    "redis:smoke": "node --env-file=.env.local --import tsx scripts/redis-smoke-test.ts",
    "worker": "node --env-file-if-exists=.env.local --import tsx src/worker.ts",
    "db:generate": "node --env-file=.env.local --import tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env.local --import tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:deploy": "node --import tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "node --env-file=.env.local --import tsx node_modules/drizzle-kit/bin.cjs studio",
    "db:test:setup": "node --import tsx scripts/db-test-setup.ts"
  },
  "dependencies": {
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "bullmq": "5.78.0",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^173.0.0",
    "ioredis": "5.10.1",
    "luxon": "3.7.2",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "6.12.4",
    "server-only": "0.0.1",
    "tsx": "4.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/luxon": "3.7.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
